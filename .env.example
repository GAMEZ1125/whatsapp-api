# Configuración del Servidor
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=*

# API Key maestra para administración global
# Genera una key segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=tu-master-key-segura-aqui

# Base de datos compartida para todos los tenants
DB_HOST=localhost
DB_PORT=3306
DB_NAME=api_whatsapp
DB_USER=root
DB_PASSWORD=
DB_POOL_LIMIT=10

# Las API Keys por tenant se generan desde /api/auth/keys usando la Master Key.
# Cada key debe asociarse al clientId del tenant correspondiente.

# Configuración de WhatsApp
SESSION_NAME=whatsapp-session
HEADLESS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logs
LOG_LEVEL=info
